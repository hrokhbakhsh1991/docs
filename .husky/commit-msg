#!/usr/bin/env sh
# Conventional commits — blocks messages like "fix typo" (must be "fix: typo").
set -eu

if [ "${HUSKY:-1}" = "0" ]; then
  echo "error: HUSKY=0 is not allowed — hooks cannot be disabled for this repository." >&2
  exit 1
fi

if [ "${SKIP_HOOKS:-}" != "" ] || [ "${SKIP_HOOK:-}" != "" ]; then
  echo "error: SKIP_HOOKS/SKIP_HOOK is not allowed — hooks cannot be bypassed." >&2
  exit 1
fi

npx --no -- commitlint --edit "$1"
