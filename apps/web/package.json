{
  "name": "@apps/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "rm -rf .next && next dev -p 3000",
    "verify:denali-architecture": "tsx scripts/verify-denali-architecture.ts",
    "build": "pnpm --filter @repo/tenant-host run build && pnpm run verify:denali-architecture && next build",
    "build:smoke": "NEXT_PUBLIC_TENANT_ROOT_DOMAIN=localhost NEXT_PUBLIC_API_DYNAMIC_ORIGIN=true NEXT_PUBLIC_API_PORT=3001 NEXT_PUBLIC_E2E_WIZARD_SEED=true next build && node scripts/copy-standalone-static.mjs",
    "start": "next start -p 3000",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.spec.ts\" \"src/**/*.spec.tsx\" \"app/**/*.spec.ts\" \"lib/**/*.spec.ts\" \"tests/audit/**/*.spec.ts\" && jest --config jest.config.cjs --runInBand",
    "eslint": "eslint --max-warnings 0 \"app/**/*.{js,jsx,ts,tsx}\" \"src/**/*.{js,jsx,ts,tsx}\"",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots",
    "qa:smoke:tour-wizard": "pnpm run build:smoke && CI=1 PW_NO_REUSE_SERVER=1 playwright test -c playwright.smoke.config.ts src/features/tours/__tests__/smoke/01-tour-wizard-new.spec.ts src/features/tours/__tests__/smoke/02-tour-wizard-cinema-theme-profile.spec.ts src/features/tours/__tests__/smoke/04-tour-wizard-urban-profile.spec.ts src/features/tours/__tests__/smoke/05-tour-wizard-preset-form-profile-filter.spec.ts src/features/tours/__tests__/smoke/07-tour-edit-urban-patch.spec.ts src/features/tours/__tests__/smoke/08-tour-wizard-mix-profile-flip.spec.ts src/features/tours/__tests__/smoke/10-denali-wizard-shell.spec.ts",
    "qa:integration:wizard-tenants": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/wizard-real-stack.shell.spec.ts",
    "qa:integration:wizard-submit-urban": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/wizard-real-stack.submit-urban.spec.ts",
    "qa:integration:wizard-submit": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/wizard-real-stack.submit-*.spec.ts",
    "qa:integration:wizard-submit-denali": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/wizard-real-stack.submit-denali-mountain.spec.ts --project=denali-submit",
    "qa:integration:wizard-submit-denali-matrix": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/wizard-real-stack.submit-denali-matrix.spec.ts --project=denali-submit",
    "qa:integration:denali-map-fields": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 PW_WEB_PORT=3000 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/wizard-real-stack.denali-map-fields.spec.ts --project=denali-submit",
    "qa:smoke:denali-map-fields": "pnpm run build:smoke && CI=1 PW_NO_REUSE_SERVER=1 playwright test -c playwright.smoke.config.ts src/features/tours/__tests__/smoke/13-denali-wizard-map-fields-dom.spec.ts",
    "qa:integration:wizard-submit-denali-from-preset": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/wizard-real-stack.submit-denali-from-preset.spec.ts --project=denali-submit",
    "qa:integration:wizard-submit-denali-from-preset-in-wizard": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/wizard-real-stack.submit-denali-from-preset-in-wizard.spec.ts --project=denali-submit",
    "qa:denali:owner-matrix": "node --env-file=.env.local --import tsx scripts/qa-denali-owner-matrix.ts",
    "qa:denali:preset-wire": "node --env-file=../api/.env --import tsx scripts/qa-denali-preset-wire.ts",
    "qa:integration:wizard-tenants:all": "PW_REAL_STACK=1 PW_NO_WEB_SERVER=1 playwright test -c playwright.integration.config.ts src/features/tours/__tests__/integration/",
    "auth:test": "node --env-file=.env.local --import tsx scripts/login-test.ts",
    "generate:denali-wizard": "tsx scripts/generate-denali-wizard-config.ts",
    "audit:denali-registry": "tsx scripts/registry-integrity-audit.ts",
    "verify:schema-parity": "tsx --tsconfig tsconfig.json ../../scripts/verify-schema-parity.ts"
  },
  "dependencies": {
    "@casl/react": "^6.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@repo/config": "workspace:*",
    "@repo/digit-localization": "workspace:*",
    "@repo/draft-engine": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/shared-contracts": "workspace:*",
    "@repo/tenant-host": "workspace:*",
    "@repo/types": "workspace:*",
    "@tanstack/react-query": "^5",
    "@tanstack/react-virtual": "^3.13.0",
    "@tour/ui": "workspace:*",
    "axios": "^1.15.2",
    "js-cookie": "^3.0.5",
    "leaflet": "^1.9.4",
    "next": "14.2.35",
    "next-intl": "^4.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "react-leaflet": "^4.2.1",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "dotenv": "^17.2.3",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.15",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.9",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.6.0"
  }
}
