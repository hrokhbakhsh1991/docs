{
  "name": "@apps/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "rm -rf .next && next dev -p 3000",
    "build": "next build",
    "build:smoke": "NEXT_PUBLIC_API_URL=http://127.0.0.1:3000/api/v2 NEXT_PUBLIC_API_DYNAMIC_ORIGIN=false next build",
    "start": "next start -p 3000",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.spec.ts\" \"app/**/*.spec.ts\"",
    "eslint": "eslint --max-warnings 0 \"app/**/*.{js,jsx,ts,tsx}\" \"src/**/*.{js,jsx,ts,tsx}\"",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots",
    "qa:smoke:tour-wizard": "pnpm run build:smoke && CI=1 PW_NO_REUSE_SERVER=1 playwright test tests/smoke/01-tour-wizard-new.spec.ts tests/smoke/02-tour-wizard-cinema-theme-profile.spec.ts tests/smoke/03-tour-wizard-submit-urban.spec.ts tests/smoke/04-tour-wizard-urban-profile.spec.ts tests/smoke/05-tour-wizard-preset-form-profile-filter.spec.ts tests/smoke/06-tour-wizard-clone-query.spec.ts tests/smoke/07-tour-edit-urban-patch.spec.ts",
    "auth:test": "node --env-file=.env.local --import tsx scripts/login-test.ts"
  },
  "dependencies": {
    "@casl/react": "^6.0.0",
    "@repo/shared-rbac": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@repo/digit-localization": "workspace:*",
    "@repo/types": "workspace:*",
    "@tanstack/react-query": "^5",
    "@tanstack/react-virtual": "^3.13.0",
    "@tour/ui": "workspace:*",
    "axios": "^1.15.2",
    "js-cookie": "^3.0.5",
    "next": "^14.2.15",
    "next-intl": "^4.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "tsx": "^4.20.6",
    "typescript": "^5.6.2"
  }
}
