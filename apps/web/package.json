{
  "name": "@apps/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "rm -rf .next && next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.spec.ts\"",
    "eslint": "eslint --max-warnings 0 \"app/**/*.{js,jsx,ts,tsx}\" \"src/**/*.{js,jsx,ts,tsx}\"",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots",
    "auth:test": "node --env-file=.env.local --import tsx scripts/login-test.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@repo/digit-localization": "workspace:*",
    "@repo/types": "workspace:*",
    "@tanstack/react-query": "^5",
    "@tour/ui": "workspace:*",
    "axios": "^1.15.2",
    "js-cookie": "^3.0.5",
    "next": "^14.2.15",
    "next-intl": "^4.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.15",
    "tsx": "^4.20.6",
    "typescript": "^5.6.2"
  }
}
