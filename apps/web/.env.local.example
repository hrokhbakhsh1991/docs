# Copy to `.env.local` for local development (Next.js loads this automatically).
# Required for SSR / Node and as fallback when not using dynamic browser origin:
# Multi-tenant local: resolve API from browser host (ws1-rbac.localhost → ws1-rbac.localhost:3001)
NEXT_PUBLIC_API_DYNAMIC_ORIGIN=true
NEXT_PUBLIC_API_PORT=3001

# Do NOT set NEXT_PUBLIC_API_URL to a fixed tenant (e.g. denali.localhost) when testing ws*-rbac fixtures.
# NEXT_PUBLIC_API_URL=http://localhost:3001
#
# Single image, many tenants: in the browser, call the API on the same hostname as the UI
# so `Host` carries the tenant subdomain. When API runs on another port (e.g. docker-compose):
# NEXT_PUBLIC_API_DYNAMIC_ORIGIN=true
# NEXT_PUBLIC_API_PORT=3001
#
# Must match API `TENANT_ROOT_DOMAIN` so workspace switching can navigate `{slug}.{root}` (optional locally).
# NEXT_PUBLIC_TENANT_ROOT_DOMAIN=localhost
#
# Denali 6-tab create wizard on subdomain `denali` (production: set to 1 after rollout).
# `denali_pilot` themes always use the Denali rail regardless of this flag.
# NEXT_PUBLIC_DENALI_SIX_TAB_WIZARD=1
#
# Phase 5: Denali canonical UI (default ON). Set to 0 for emergency rollback to form mirror.
# NEXT_PUBLIC_DENALI_CANONICAL_UI_MODE=0
#
# Behind a reverse proxy only: trust `x-forwarded-host` when the direct peer IP is in CIDRs (fail-closed if unset).
# Never enable on paths reachable directly from the public internet without a trusted proxy in front.
# NEXT_PUBLIC_TRUST_PROXY=false
# NEXT_PUBLIC_TRUSTED_PROXY_CIDRS=127.0.0.1/32,10.0.0.0/8
#
# BFF tour detail aggregation (`GET /api/tours/[tourId]` → resolved gear/themes).
# Must match `INTERNAL_API_KEY` in apps/api/.env (see apps/api/.env.example).
# INTERNAL_API_KEY=replace-with-long-random-secret
#
# Dev CORS on API: set CORS_ALLOW_TENANT_SUBORIGINS=true in apps/api/.env when UI runs on *.localhost.
#
# Middleware workspace lookup uses GET /api/v2/auth/workspace-host (override path if needed).
# WORKSPACE_LOOKUP_CACHE_TTL_MS=60000
# WORKSPACE_LOOKUP_PROBE_PATH=/api/v2/auth/workspace-host
#
# Session cookie Domain (optional). Development defaults to host-only (reliable on denali.localhost).
# Opt-in cross-subdomain dev sharing: NEXT_PUBLIC_SESSION_COOKIE_DOMAIN=.localhost
# Production: set NEXT_PUBLIC_SESSION_COOKIE_DOMAIN=.company.com
# Explicit host-only (same as default in dev):
NEXT_PUBLIC_SESSION_COOKIE_DOMAIN=host-only
#
# Cookie SameSite: strict (default) | lax | none (none forces Secure=true).
# NEXT_PUBLIC_SESSION_COOKIE_SAME_SITE=strict
#
# Optional: switch leader/review to future aggregate endpoint path.
# NEXT_PUBLIC_LEADER_DASHBOARD_USE_AGGREGATE_API=false
# Participant payment intent (`POST /api/v2/payments/intent`); must match API DEFAULT_PAYMENT_PROVIDER / tenant PSP.
# Production: set to stripe or zibal — never mock_provider.
NEXT_PUBLIC_PAYMENT_PROVIDER=mock_provider
# Optional: when tour has no usable price, still allow intents in dev (smallest currency units — e.g. cents for USD).
# NEXT_PUBLIC_PAYMENT_INTENT_FALLBACK_AMOUNT=100
# NEXT_PUBLIC_PAYMENT_INTENT_FALLBACK_CURRENCY=USD
#
# Optional geocoding providers (server-only; Neshan tried before Map.ir, then Nominatim fallback):
# NESHAN_API_KEY=
# MAP_IR_TOKEN=
#
# Optional: tour-create debug ingest (Cursor/agent session logger). Unset = no network calls.
# NEXT_PUBLIC_DEBUG_SESSION_INGEST_URL=http://127.0.0.1:7807/ingest/7d27fed5-b89d-4f95-845a-1f85c5808f1a
#
# Optional: log denali wizard diagnostic JSON on review step mount.
# NEXT_PUBLIC_DENALI_WIZARD_DIAGNOSTIC=1
