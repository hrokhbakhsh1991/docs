{
  "name": "@apps/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build && node dist/src/openapi.generate.js",
    "start": "node dist/src/main.js",
    "dev": "pnpm build && node dist/src/main.js",
    "dev:watch": "tsc -w",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test \"test/outbox/**/*.ts\" \"test/registrations/**/*.unit-spec.ts\" \"test/registrations/**/*.e2e-spec.ts\" \"test/reconciliation/**/*.ts\" \"test/payments/**/*.ts\" \"test/idempotency/**/*.ts\" \"test/tenant-isolation.spec.ts\" \"test/rls-guardrail.spec.ts\" \"src/**/*.spec.ts\"",
    "test:e2e": "node --import tsx --test test/api.e2e-spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jose": "^6.1.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^5.0.6",
    "@types/node": "^22.7.4",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.6.2"
  }
}
