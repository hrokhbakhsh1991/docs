{
  "name": "@apps/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build && node dist/openapi.generate.js",
    "seed": "node --env-file=.env --import tsx src/scripts/seed.ts",
    "seed:rbac-rollout": "node --env-file=.env --import tsx src/scripts/seed-rbac-rollout.ts",
    "rbac-rollout:reset-db": "TS_MIGRATIONS=1 node --env-file=.env --import tsx src/scripts/rbac-rollout-reset-db.ts",
    "rbac-rollout:verify": "node --env-file=.env --import tsx src/scripts/rbac-rollout-verify.ts",
    "seed:bulk-test-users": "node --env-file=.env --import tsx src/scripts/seed-bulk-test-users.ts",
    "seed:demo-leader-tours": "node --env-file=.env --import tsx src/scripts/seed-demo-leader-tours.ts",
    "seed:denali-tour-presets": "node --env-file=.env --import tsx src/scripts/seed-denali-tour-presets.ts",
    "seed:denali-tours": "node --env-file=.env --import tsx src/scripts/seed-denali-tours.ts",
    "seed:denali-equipment": "node --env-file=.env --import tsx src/scripts/seed-denali-equipment.ts",
    "seed:denali-locations": "node --env-file=.env --import tsx src/scripts/seed-denali-locations.ts",
    "provision:denali": "node --env-file=.env --import tsx src/scripts/provision-denali-tenant.ts",
    "provision:tenant": "node --env-file=.env --import tsx src/scripts/provision-tenant.ts",
    "verify:denali": "node --env-file=.env --import tsx src/scripts/verify-denali-tenant.ts",
    "verify:tenant": "node --env-file=.env --import tsx src/scripts/verify-tenant.ts",
    "probe:tour-create": "node --env-file=.env --import tsx src/scripts/probe-workspace-tour-create.ts",
    "probe:tour-draft": "node --env-file=.env --import tsx src/scripts/probe-workspace-tour-draft.ts",
    "qa:probe-wizard-tenants": "node --env-file=.env --import tsx src/scripts/probe-workspace-tour-create.ts -- --slug=denali && node --env-file=.env --import tsx src/scripts/probe-workspace-tour-create.ts -- --slug=urban-demo && node --env-file=.env --import tsx src/scripts/probe-workspace-tour-create.ts -- --slug=mix-demo",
    "qa:probe-wizard-drafts": "node --env-file=.env --import tsx src/scripts/probe-workspace-tour-draft.ts -- --slug=denali && node --env-file=.env --import tsx src/scripts/probe-workspace-tour-draft.ts -- --slug=urban-demo && node --env-file=.env --import tsx src/scripts/probe-workspace-tour-draft.ts -- --slug=mix-demo",
    "seed:leader-bookings": "node --env-file=.env --import tsx src/scripts/seed-leader-bookings.ts",
    "auth:debug-audit": "node --env-file=.env --import tsx src/scripts/auth-debug-audit.ts",
    "e2e:freeze": "node --env-file=.env --import tsx src/scripts/freeze-e2e.ts",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:worker": "APP_RUNTIME_ROLE=worker ENABLE_SCHEDULERS=true node dist/main.js",
    "dev": "pnpm --filter @repo/config run build && pnpm build && node --env-file=.env dist/main.js",
    "dev:watch": "tsc -w",
    "lint": "tsc --noEmit",
    "lint:fitness": "node --import tsx --test src/modules/tours/fitness.spec.ts",
    "test": "node --import tsx --test \"test/outbox/**/*.ts\" \"test/registrations/**/*.unit-spec.ts\" \"test/registrations/**/*.e2e-spec.ts\" \"test/reconciliation/**/*.ts\" \"test/payments/**/*.ts\" \"test/pricing/**/*.ts\" \"test/idempotency/**/*.ts\" \"test/guards/**/*.ts\" \"test/jobs/**/*.ts\" \"test/security/**/*.ts\" \"test/modules/**/*.unit-spec.ts\" \"test/tenant-isolation.spec.ts\" \"test/rls-guardrail.spec.ts\" \"src/**/*.spec.ts\"",
    "test:e2e": "node --import tsx --test test/api.e2e-spec.ts test/e2e/registrations.e2e-spec.ts test/e2e/tenant-isolation.e2e-spec.ts test/e2e/jwt-membership-guard.e2e-spec.ts test/e2e/me-profile.e2e-spec.ts test/e2e/subdomain-multi-tenant.e2e-spec.ts test/e2e/subdomain-comprehensive.e2e-spec.ts test/e2e/invite-role-hierarchy.e2e-spec.ts test/e2e/users-role-rbac.e2e-spec.ts test/e2e/users-cursor-bulk.e2e-spec.ts test/e2e/invite-accept-function.e2e-spec.ts test/e2e/invite-accept-parallel.e2e-spec.ts test/e2e/tenant-context-leak.e2e-spec.ts test/e2e/payments-webhook-wrong-tenant.e2e-spec.ts test/e2e/ownership-transfer.e2e-spec.ts test/e2e/tours-create.e2e-spec.ts",
    "openapi:dev": "nest build && node dist/openapi.generate.js",
    "migrate:run": "TS_MIGRATIONS=1 node --env-file=.env --import tsx src/scripts/run-migrations.ts",
    "schema:align": "node --env-file=.env --import tsx src/scripts/align-post-login-schema.ts",
    "migrate:tour-theme-tags": "node --env-file=.env --import tsx src/scripts/migrate-tour-theme-tags.ts"
  },
  "dependencies": {
    "@casl/ability": "^6.7.3",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/core": "^1.30.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.1",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@repo/config": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/tenant-host": "workspace:*",
    "@repo/shared-contracts": "workspace:*",
    "@repo/types": "workspace:*",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.1.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.0.1",
    "rxjs": "^7.8.1",
    "stripe": "^22.1.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.22",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.7.4",
    "@types/supertest": "^7.2.0",
    "bcrypt": "^6.0.0",
    "express": "^4.21.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.6.2"
  }
}
