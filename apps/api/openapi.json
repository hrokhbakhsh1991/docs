  "info": {
    "title": "API v2 Documentation",
    "description": "",
    "version": "2.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "/api/v2"
    }
  ],
  "components": {
    "schemas": {
      "WebCredentialDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "leader@example.com",
            "description": "User email address for web login"
          },
          "password": {
            "type": "string",
            "example": "Passw0rd!",
            "description": "Plain text password for authentication"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "WebSessionDto": {
        "type": "object",
        "properties": {
          "entry_mode": {
            "type": "string",
            "example": "web",
            "enum": [
              "web"
            ]
          },
          "credential": {
            "$ref": "#/components/schemas/WebCredentialDto"
          },
          "asserted_tenant_id": {
            "type": "string",
            "example": "11111111-1111-4111-8111-111111111111",
            "description": "Optional tenant assertion from trusted client context"
          }
        },
        "required": [
          "entry_mode",
          "credential"
        ]
      },
      "TelegramSessionDto": {
        "type": "object",
        "properties": {
          "entry_mode": {
            "type": "string",
            "example": "telegram",
            "enum": [
              "telegram"
            ]
          },
          "telegram_init_payload": {
            "type": "string",
            "example": "query_id=AAHdF6IQAAAAAN0XohDhrOrc&user=%7B%22id%22%3A123456789%7D&auth_date=1714000000&hash=abcdef",
            "description": "Telegram init data payload from Telegram WebApp"
          },
          "asserted_tenant_id": {
            "type": "string",
            "example": "11111111-1111-4111-8111-111111111111"
          }
        },
        "required": [
          "entry_mode",
          "telegram_init_payload"
        ]
      },
      "LinkTelegramDto": {
        "type": "object",
