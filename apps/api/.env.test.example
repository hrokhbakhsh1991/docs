# Test runtime mode for deterministic behavior
NODE_ENV=test

# App runtime role (API only during E2E)
APP_RUNTIME_ROLE=api

# Application port used in test process
APP_PORT=3001
PORT=3001

# Database connection (requested keys)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tours_test
DB_USERNAME=test_user
DB_PASSWORD=test_pass

# Database connection (Nest runtime keys used by current backend)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tours_test
DATABASE_USER=test_user
DATABASE_PASSWORD=test_pass
DATABASE_URL=postgres://test_user:test_pass@localhost:5432/tours_test

# Redis connection for queues/locks
REDIS_HOST=localhost
REDIS_PORT=6379
# In tests we do not trust forwarding headers unless explicitly overridden.
TRUSTED_PROXY_CIDRS=

# Tenant Redis rate limits: off by default for E2E throughput (enable with true to test limits)
TENANT_RATE_LIMIT_ENABLED=false
# Redis failure handling for limits: degraded (in-memory fallback) | fail_closed | fail_open
RATE_LIMIT_FAIL_MODE=degraded

# JWT test secrets (requested keys)
JWT_SECRET=test_jwt_secret
JWT_EXPIRES_IN=12h

# JWT runtime keys used by current backend
JWT_PRIVATE_KEY=test-private-key
JWT_PUBLIC_KEY=test-public-key
JWT_ISSUER=test-issuer
JWT_AUDIENCE=test-audience

# Disable schedulers for stable E2E
ENABLE_SCHEDULERS=false

# Payment/webhook placeholders for integration tests
STRIPE_SECRET_KEY=sk_test_xxxxx
PAYMENT_WEBHOOK_SECRET=whsec_test_xxxxx

# Internal API key used by internal routes in tests
INTERNAL_API_KEY=test-internal-key

# HMAC for POST /internal/payments/webhook (bootstrap also injects a default if unset)
PAYMENTS_WEBHOOK_SIGNING_SECRET=test-webhook-hmac-secret-at-least-32chars!!!!
PAYMENTS_WEBHOOK_ALLOWED_IPS=

# Idempotency behavior
IDEMPOTENCY_ENABLED=true

# Telegram token used by auth payload verification tests
TELEGRAM_BOT_TOKEN=test-token
# Web session E2E helpers use OTP `1234` when no SMS provider; set `false` in `.env.test` only for prod-like OTP tests.
AUTH_ALLOW_DEV_STATIC_OTP=true

# Keep logs compact in tests
LOG_LEVEL=error
