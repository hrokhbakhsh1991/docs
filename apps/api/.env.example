# API runtime (see apps/api/src/config/env.schema.ts)
# valid values: development | test | production
NODE_ENV=development
# Applies to runtime logs (LoggerService / pino) and CLI scripts (e.g. migrate/seed info output).
LOG_LEVEL=info
PORT=3000

# Tenant abuse / Redis sliding-window limits (see docs/tenant-rate-limiting.md)
# TENANT_RATE_LIMIT_ENABLED=true
# TENANT_RATE_LIMIT_API_WINDOW_MS=60000
# TENANT_RATE_LIMIT_API_PER_TENANT=6000
# TENANT_RATE_LIMIT_API_PER_USER=1200
# TENANT_RATE_LIMIT_API_PER_IP=3000
# TENANT_RATE_LIMIT_LOGIN_WINDOW_MS=60000
# TENANT_RATE_LIMIT_LOGIN_PER_TENANT=60
# TENANT_RATE_LIMIT_LOGIN_PER_IP=30
# TENANT_RATE_LIMIT_JOB_WINDOW_MS=60000
# TENANT_RATE_LIMIT_JOB_PER_TENANT=120
# RATE_LIMIT_FAIL_MODE=degraded  # degraded | fail_closed | fail_open

# OpenTelemetry traces (OTLP HTTP). See docs/docs/observability-monitoring.md
# OTEL_SDK_DISABLED=true
# OTEL_SERVICE_NAME=tour-ops-api
# Local Jaeger (pnpm docker:observability from repo root):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# UI: http://localhost:16686
# Or full URL: OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces

# PostgreSQL — defaults aligned with infra/docker-compose.yml (change both together if you rotate secrets)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_USER=tour_ops
DATABASE_PASSWORD=tour_ops
DATABASE_NAME=tour_ops_dev
DATABASE_URL=postgresql://tour_ops:tour_ops@127.0.0.1:5433/tour_ops_dev
# When unset: dev/test auto-create missing `resolve_tour_tenant_for_public_flow(uuid)` at API boot (idempotent). Production defaults off — set to 1/true to opt in, or run migrations instead.
# DATABASE_AUTO_CREATE_PUBLIC_FLOW_FUNCTION=0

# JWT verification (RS256)
# Private key is used by /api/v2/auth/* session signing.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_REAL_KEY\n-----END PRIVATE KEY-----"
# Use a PEM-encoded public key. Keep newline escapes if using .env format.
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_REAL_KEY\n-----END PUBLIC KEY-----"
JWT_ISSUER=replace-with-issuer
JWT_AUDIENCE=replace-with-audience
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
# UNSAFE local-only helper: allows static OTP value `1234` when NODE_ENV=development.
# Never enable in staging/preprod/production.
AUTH_ALLOW_DEV_STATIC_OTP=true

# Redis (local Docker default)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# CORS: comma-separated browser origins (leave empty to disallow cross-origin browser calls)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:3000
# Production multi-tenant UI: allow any origin whose hostname matches TENANT_ROOT_DOMAIN or *.TENANT_ROOT_DOMAIN (HTTPS required except localhost).
# Dev with UI on ws*.localhost: set true so browser CORS allows tenant suborigins.
# CORS_ALLOW_TENANT_SUBORIGINS=true
# Express trust proxy hops (X-Forwarded-Host / req.hostname). 0 = off; 1 = single reverse proxy; CDN+ingress often 2+.
# TRUST_PROXY_HOPS=1
# Strict trust boundary for X-Forwarded-For parsing (comma-separated CIDRs/IPs). Empty => ignore X-Forwarded-For.
# TRUSTED_PROXY_CIDRS=10.0.0.0/8,192.168.0.0/16,127.0.0.1/32
# Optional canonical UI origin for workspace invite links (overrides first CORS_ORIGIN when set).
# PUBLIC_WEB_ORIGIN=

# Host-based tenant subdomain routing (optional). Leave TENANT_ROOT_DOMAIN empty to disable.
# Example: TENANT_ROOT_DOMAIN=app.example.com matches hosts like acme.app.example.com → tenant slug acme.
# TENANT_ROOT_DOMAIN=
# Comma-separated labels that never map to tenants (www, api, admin, internal, root, …).
# TENANT_HOST_RESERVED_SUBDOMAINS=www,api,app,mail,ftp,cdn,static,assets,localhost,staging,admin,internal,root

# Scheduler runtime controls
# - ENABLE_SCHEDULERS=false => no in-process scheduler will run
# - APP_RUNTIME_ROLE=api => API-only pod/process (no schedulers)
# - APP_RUNTIME_ROLE=worker => worker-only pod/process (schedulers enabled)
# - APP_RUNTIME_ROLE=all => combined mode (local/dev only)
ENABLE_SCHEDULERS=true
APP_RUNTIME_ROLE=all
JOB_SCHEDULER_JITTER_MS=500

# Internal ops (GET /internal/ops/*) — send header x-internal-api-key
INTERNAL_API_KEY=replace-with-long-random-secret

# Payment provider webhook HMAC (POST /internal/payments/webhook) — min 16 chars; optional previous secret for rotation
PAYMENTS_WEBHOOK_SIGNING_SECRET=replace-with-webhook-hmac-secret-min-16-chars
# PAYMENTS_WEBHOOK_SIGNING_SECRET_PREVIOUS=
# Comma-separated IPs; leave empty to allow any caller (lock down in production)
PAYMENTS_WEBHOOK_ALLOWED_IPS=

# Outbox worker (disabled when NODE_ENV=test)
OUTBOX_PROCESSOR_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_MAX_RETRY=5
OUTBOX_BATCH_SIZE=50
# In-process domain event bus (unsafe in prod). Default false — critical flows use DB outbox only.
ENABLE_IN_MEMORY_DOMAIN_EVENTS=false

# Periodic capacity reconciliation (disabled when NODE_ENV=test)
RECONCILIATION_ENABLED=false
RECONCILIATION_INTERVAL_MS=600000
# Payment–ledger–snapshot reconciliation lookback (days; max 365). Default 30 when unset.
# PAYMENT_FINANCE_RECONCILIATION_LOOKBACK_DAYS=30

# Legacy catalog pricing drift logs (read-only; never affects totals). Default `off` — single finance quote path.
# In production this is always `off` regardless of value. Use `archive` on non-prod only for PRICING_SHADOW* logs.
# FINANCE_LEGACY_PRICING_DIAGNOSTICS=off

# Payment timeout processor (disabled when NODE_ENV=test)
PAYMENTS_TIMEOUT_ENABLED=true
PAYMENTS_TIMEOUT_INTERVAL_MS=60000

# External payment gateways (optional). `paymentProvider=stripe` uses the live SDK when STRIPE_SECRET_KEY is set.
# STRIPE_SECRET_KEY=sk_test_...
# Zibal (IRR only): set both to enable `paymentProvider=zibal`
# ZIBAL_MERCHANT=your_merchant_id
# ZIBAL_CALLBACK_URL=https://api.example.com/your/zibal/callback
# Payment-gateway idempotency: `postgres` (default outside test, durable in DB) | `redis` | `memory` (test default).
# PAYMENT_GATEWAY_IDEMPOTENCY_STORE=postgres

# Optional: public web origin for verification links in outbound email (e.g. http://denali.localhost:3000)
# FRONTEND_BASE_URL=http://denali.localhost:3000
# RESEND_API_KEY=
# RESEND_FROM=
