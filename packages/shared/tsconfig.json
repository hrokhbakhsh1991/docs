{
  "extends": "../config/tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "noEmit": false,
    "verbatimModuleSyntax": false
  },
  "include": ["index.ts", "errors/**/*.ts", "rbac/**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
