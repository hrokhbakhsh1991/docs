# Copy is not used directly — run once:
#   bash infra/scripts/docker-bootstrap-env.sh
# That writes infra/.env.docker with generated JWT keys and Postgres/Redis hosts
# aligned with infra/docker-compose.full.yml.

NODE_ENV=production
LOG_LEVEL=info
PORT=3001

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=tour_ops
DATABASE_PASSWORD=tour_ops
DATABASE_NAME=tour_ops_dev
DATABASE_URL=postgresql://tour_ops:tour_ops@postgres:5432/tour_ops_dev

# JWT_* PEM bodies are generated by docker-bootstrap-env.sh (PKCS8 private + SPKI public).
JWT_ISSUER=tour-ops-docker
JWT_AUDIENCE=tour-ops-web
TELEGRAM_BOT_TOKEN=dummy-telegram-token-docker-only

REDIS_HOST=redis
REDIS_PORT=6379

# Browser origins allowed to call the API (Docker web on localhost:3000)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

ENABLE_SCHEDULERS=true
APP_RUNTIME_ROLE=all
INTERNAL_API_KEY=change-me
