FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
WORKDIR /repo

FROM base AS builder

ARG NEXT_PUBLIC_API_URL=http://localhost:3001
ARG NEXT_PUBLIC_API_DYNAMIC_ORIGIN=false
ARG NEXT_PUBLIC_API_PORT=
ARG NEXT_PUBLIC_TENANT_ROOT_DOMAIN=
ARG NEXT_PUBLIC_SESSION_COOKIE_DOMAIN=
ARG NEXT_PUBLIC_SESSION_COOKIE_SAME_SITE=strict
ARG NEXT_PUBLIC_PAYMENT_PROVIDER=mock_provider

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_DYNAMIC_ORIGIN=$NEXT_PUBLIC_API_DYNAMIC_ORIGIN
ENV NEXT_PUBLIC_API_PORT=$NEXT_PUBLIC_API_PORT
ENV NEXT_PUBLIC_TENANT_ROOT_DOMAIN=$NEXT_PUBLIC_TENANT_ROOT_DOMAIN
ENV NEXT_PUBLIC_SESSION_COOKIE_DOMAIN=$NEXT_PUBLIC_SESSION_COOKIE_DOMAIN
ENV NEXT_PUBLIC_SESSION_COOKIE_SAME_SITE=$NEXT_PUBLIC_SESSION_COOKIE_SAME_SITE
ENV NEXT_PUBLIC_PAYMENT_PROVIDER=$NEXT_PUBLIC_PAYMENT_PROVIDER

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/ui/package.json ./packages/ui/
COPY packages/types/package.json ./packages/types/
COPY packages/config/package.json ./packages/config/
COPY packages/config/tsconfig.base.json ./packages/config/

RUN pnpm install --frozen-lockfile --filter @apps/web...

COPY apps/web ./apps/web
COPY packages/ui ./packages/ui
COPY packages/types ./packages/types

RUN pnpm --filter @apps/web run build

# Runner layout matches Next standalone + https://nextjs.org/docs/app/api-reference/config/next-config-js/output
# Standalone root (/app) contains apps/web/server.js; server chdirs to apps/web, so .next/static and public belong under apps/web/.
FROM node:22-alpine AS runner
WORKDIR /app
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001 -G nodejs
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/public ./apps/web/public
USER nextjs
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
