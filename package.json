{
  "name": "tour-ops-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "dev": "pnpm --filter @apps/api dev",
    "build": "pnpm --filter \"@apps/*\" run build",
    "lint": "pnpm --filter \"@apps/*\" run lint",
    "test": "pnpm --filter \"@apps/api\" run test",
    "e2e:infra:start": "docker compose -f docker-compose.e2e.yml up -d",
    "e2e:infra:stop": "docker compose -f docker-compose.e2e.yml down -v",
    "e2e:migrate": "pnpm --dir apps/api migrate:run",
    "test:e2e:ci": "pnpm e2e:migrate && pnpm --dir apps/api exec node --import tsx --test --test-concurrency=1 test/api.e2e-spec.ts test/e2e/registrations.e2e-spec.ts",
    "check:ui": "node scripts/validate-design-tokens.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "react-hook-form": "^7.75.0",
    "zod": "^4.3.6"
  }
}
