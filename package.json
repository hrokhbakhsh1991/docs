{
  "name": "tour-ops-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter @apps/api dev",
    "build": "pnpm --filter @repo/types run build && pnpm --filter @repo/config run build && pnpm --filter @repo/domain-contracts run build && pnpm --filter @repo/draft-engine run build && pnpm --filter @repo/shared-contracts run build && pnpm --filter @repo/shared run build && pnpm --filter \"@apps/*\" run build",
    "lint": "pnpm --filter \"@apps/*\" run lint",
    "test": "pnpm --filter @repo/draft-engine run test && pnpm --filter @repo/shared run test && pnpm --filter \"@apps/api\" run test",
    "test:security": "jest tests/security --runInBand",
    "e2e:infra:start": "docker compose -f docker-compose.e2e.yml up -d",
    "e2e:infra:stop": "docker compose -f docker-compose.e2e.yml down -v",
    "docker:bootstrap": "bash infra/scripts/docker-bootstrap-env.sh",
    "docker:stack": "docker compose -f infra/docker-compose.full.yml up --build -d",
    "docker:stack:down": "docker compose -f infra/docker-compose.full.yml down",
    "docker:observability": "docker compose -f infra/docker-compose.observability.yml up -d",
    "docker:observability:down": "docker compose -f infra/docker-compose.observability.yml down",
    "infra:verify": "node scripts/run-infrastructure-closure-verify.mjs",
    "infra:verify:live": "node scripts/verify-infrastructure-reality-gate.mjs",
    "infra:verify:all": "node scripts/run-infrastructure-closure-verify.mjs && node scripts/verify-infrastructure-reality-gate.mjs",
    "infra:verify:logs": "node scripts/verify-production-log-sample.mjs",
    "infra:signoff": "node scripts/infrastructure-closure-signoff.mjs",
    "infra:signoff:live": "node scripts/infrastructure-closure-signoff.mjs --live",
    "infra:complete": "node scripts/apply-infrastructure-closure-remaining.mjs",
    "debug:draft-engine": "pnpm --dir apps/api exec node --import tsx ../../scripts/debug-draft-engine.ts",
    "e2e:migrate": "pnpm --dir apps/api migrate:run",
    "test:e2e:ci": "pnpm --filter @repo/types run build && pnpm --filter @repo/shared run build && pnpm e2e:migrate && pnpm --dir apps/api exec node --import tsx --test --test-concurrency=1 test/api.e2e-spec.ts test/e2e/registrations.e2e-spec.ts test/e2e/payments-webhook-wrong-tenant.e2e-spec.ts",
    "check:ui": "node scripts/validate-design-tokens.js",
    "guardrails:tour-rbac-parity": "node scripts/check-tour-rbac-parity.mjs",
    "guardrails:tour-rbac-parity:tests": "node scripts/run-tour-parity-unit-tests.mjs",
    "guardrails:tour-governance": "node scripts/run-tour-governance.mjs",
    "guardrails:tour-governance:tests": "node scripts/run-tour-governance.mjs --tests",
    "guardrails:tenant-isolation": "node scripts/check-tenant-isolation-guardrails.mjs",
    "guardrails:public-registration-idempotency": "node scripts/check-public-registration-idempotency.mjs",
    "guardrails:test-pairing": "node scripts/check-test-pairing.mjs",
    "guardrails:test-owners": "node scripts/check-test-owners.mjs",
    "qa:tour-wizard-smoke": "pnpm --dir apps/web run qa:smoke:tour-wizard",
    "tsc": "pnpm --filter @repo/shared run lint && pnpm --filter @repo/domain-contracts run lint && pnpm --filter @repo/shared-contracts run lint && pnpm --filter @repo/draft-engine run lint && pnpm --filter @apps/api exec tsc --noEmit && pnpm --filter @apps/web exec tsc --noEmit && pnpm --filter @tour/ui run build && pnpm --filter @apps/telegram run lint",
    "depcruise:check": "depcruise --config dependency-cruiser.config.js apps --output-type err-long",
    "eslint": "eslint . --max-warnings 0",
    "depcruise:validate": "depcruise --validate dependency-cruiser.config.js",
    "depcruise": "depcruise --config dependency-cruiser.config.js . --output-type err-long",
    "audit:duplication": "jscpd apps packages --ignore \"**/*.spec.ts,**/*.test.ts,**/node_modules/**,**/dist/**,.next/**\"",
    "fix:barrels": "node scripts/fix-barrels.mjs --write",
    "fix:unused-vars": "node scripts/remove-unused-vars.mjs --write",
    "test:precommit": "node scripts/precommit-jest-staged.mjs",
    "test-pairing:staged": "node scripts/precommit-test-pairing-staged.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "react-hook-form": "^7.75.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-plugin-test-pairing": "workspace:*",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jscpd": "^4.2.4",
    "lint-staged": "^17.0.5",
    "nx": "22.7.1",
    "ts-jest": "^29.4.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --max-warnings 0",
      "depcruise --config dependency-cruiser.config.js --output-type err-long",
      "node scripts/precommit-tsc-staged.mjs",
      "node scripts/precommit-test-pairing-staged.mjs",
      "node scripts/precommit-jest-staged.mjs"
    ]
  }
}