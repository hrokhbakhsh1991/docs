{
  "name": "tour-ops-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "dev": "pnpm --filter @apps/api dev",
    "build": "pnpm --filter @repo/types run build && pnpm --filter @repo/config run build && pnpm --filter @repo/shared-contracts run build && pnpm --filter @repo/shared run build && pnpm --filter \"@apps/*\" run build",
    "lint": "pnpm --filter \"@apps/*\" run lint",
    "test": "pnpm --filter @repo/shared run test && pnpm --filter \"@apps/api\" run test",
    "test:security": "jest tests/security --runInBand",
    "e2e:infra:start": "docker compose -f docker-compose.e2e.yml up -d",
    "e2e:infra:stop": "docker compose -f docker-compose.e2e.yml down -v",
    "docker:bootstrap": "bash infra/scripts/docker-bootstrap-env.sh",
    "docker:stack": "docker compose -f infra/docker-compose.full.yml up --build -d",
    "docker:stack:down": "docker compose -f infra/docker-compose.full.yml down",
    "docker:observability": "docker compose -f infra/docker-compose.observability.yml up -d",
    "docker:observability:down": "docker compose -f infra/docker-compose.observability.yml down",
    "infra:verify": "node scripts/run-infrastructure-closure-verify.mjs",
    "infra:verify:live": "node scripts/verify-infrastructure-reality-gate.mjs",
    "infra:verify:all": "node scripts/run-infrastructure-closure-verify.mjs && node scripts/verify-infrastructure-reality-gate.mjs",
    "infra:verify:logs": "node scripts/verify-production-log-sample.mjs",
    "infra:signoff": "node scripts/infrastructure-closure-signoff.mjs",
    "infra:signoff:live": "node scripts/infrastructure-closure-signoff.mjs --live",
    "infra:complete": "node scripts/apply-infrastructure-closure-remaining.mjs",
    "e2e:migrate": "pnpm --dir apps/api migrate:run",
    "test:e2e:ci": "pnpm --filter @repo/types run build && pnpm --filter @repo/shared run build && pnpm e2e:migrate && pnpm --dir apps/api exec node --import tsx --test --test-concurrency=1 test/api.e2e-spec.ts test/e2e/registrations.e2e-spec.ts",
    "check:ui": "node scripts/validate-design-tokens.js",
    "guardrails:tour-rbac-parity": "node scripts/check-tour-rbac-parity.mjs",
    "guardrails:tour-rbac-parity:tests": "node scripts/run-tour-parity-unit-tests.mjs",
    "guardrails:tour-governance": "node scripts/run-tour-governance.mjs",
    "guardrails:tour-governance:tests": "node scripts/run-tour-governance.mjs --tests",
    "guardrails:tenant-isolation": "node scripts/check-tenant-isolation-guardrails.mjs",
    "guardrails:public-registration-idempotency": "node scripts/check-public-registration-idempotency.mjs",
    "qa:tour-wizard-smoke": "pnpm --dir apps/web run qa:smoke:tour-wizard",
    "tsc": "pnpm --filter @repo/shared run lint && pnpm --filter @repo/shared-contracts run lint && pnpm --filter @apps/api exec tsc --noEmit && pnpm --filter @apps/web exec tsc --noEmit && pnpm --filter @tour/ui run build && pnpm --filter @apps/telegram run lint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "react-hook-form": "^7.75.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "nx": "22.7.1"
  }
}